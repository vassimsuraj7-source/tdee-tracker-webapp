{
  "name": "@tdee/engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pure TDEE calculation engine ported from the native TDEETracker app. No I/O, fully unit-testable.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
