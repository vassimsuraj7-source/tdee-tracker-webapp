# Copy to .env and fill in real values. NEVER commit .env (Req 22.2).
# Real secrets are provisioned via Supabase secrets/environment at deploy time.

# Hashed Ingestion API key (salted hash, not the raw key) — Req 1.3
INGEST_API_KEY_HASH=

# Supabase project (from the Supabase dashboard)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key is used ONLY inside Edge Functions, never shipped to the browser
SUPABASE_SERVICE_ROLE_KEY=

# User's IANA time zone for local-day normalization and the pre-midnight recompute
USER_TIME_ZONE=Europe/Luxembourg
