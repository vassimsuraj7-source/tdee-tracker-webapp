# Copy to web/.env for local dev. Client-safe values only (the publishable key is
# RLS-protected). For the deployed build, set these as GitHub repo Variables instead
# (see .github/workflows/deploy.yml). Never put the service_role key here.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key
